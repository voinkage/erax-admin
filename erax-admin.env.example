# ERAX Admin - Örnek ortam değişkenleri (.env dosyasına kopyalayıp doldurun)

# Veritabanları
# KULLANICI_DB_URL=
# ORGANIZASYON_DB_URL=
# ICERIK_DB_URL=
# SEVIYE_DB_URL=
# DIGIBUCH_DB_URL=

# JWT (admin girişi)
# JWT_SECRET=

# CORS, port
# CORS_ORIGIN=
# PORT=3010

# Liderlik tablosu CDN + puan sıfırlama
# KULLANICI_BACKEND_URL=   # eradil-kullanici API adresi
# LIDERLIK_EXPORT_SECRET=  # kullanici backend internal istekler için
# OZEL_ISLEM_KEY=         # Admin panelde "Herkesin puanını sıfırla" işlemi için; bu değeri modalda girmeniz gerekir
